# =============================================================================
# kie.ai — image / video generation (Grok Imagine)
# =============================================================================
# Sign up at https://kie.ai to get an API key (free credits on signup).
# You can put one or more keys here, comma / whitespace / newline separated.
# Users can also paste their own keys via Settings → Keys in the UI; both
# pools are merged on every request. Leave empty if you only use the in-app UI.
KIE_API_KEYS=

# =============================================================================
# OpenRouter — chat backend (optional)
# =============================================================================
# Get a key at https://openrouter.ai/keys. The default chat model is
# `openrouter/owl-alpha`. Leave empty to disable the /chat page.
OPENROUTER_API_KEY=

# =============================================================================
# Site config
# =============================================================================
# Optional simple password gate. Empty = no gate.
SITE_PASSWORD=

# Public URL of your deployment, used as HTTP-Referer on OpenRouter requests.
# On Vercel: NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
